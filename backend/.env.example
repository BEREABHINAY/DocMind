# Copy this file to .env and fill in your own values.
# Get a free Groq API key at https://console.groq.com

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Leave both blank to use local/embedded Qdrant (zero setup, data
# stored on disk at QDRANT_LOCAL_PATH). Fill in QDRANT_URL (and
# QDRANT_API_KEY if needed) to point at a Qdrant Cloud cluster instead,
# which is what you'll want once you deploy to Render, since Render's
# free tier disk is not guaranteed to persist across restarts.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_LOCAL_PATH=./qdrant_data

COLLECTION_NAME=documents
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=40
TOP_K=5
